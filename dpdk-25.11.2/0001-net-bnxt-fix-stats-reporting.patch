From 0420762f7d956551c726f5fc5c5ad99943566f55 Mon Sep 17 00:00:00 2001
From: Oleksandr Nahnybida <oleksandrn@interfacemasters.com>
Date: Fri, 26 Jun 2026 17:24:35 +0300
Subject: [PATCH] net/bnxt: fix stats reporting

---
 drivers/net/bnxt/bnxt_hwrm.c | 133 +++++++++++++++++++++++------------
 1 file changed, 88 insertions(+), 45 deletions(-)

diff --git a/drivers/net/bnxt/bnxt_hwrm.c b/drivers/net/bnxt/bnxt_hwrm.c
index c1332f796b..d567a51a6e 100644
--- a/drivers/net/bnxt/bnxt_hwrm.c
+++ b/drivers/net/bnxt/bnxt_hwrm.c
@@ -5385,8 +5385,6 @@ int bnxt_hwrm_fwd_resp(struct bnxt *bp, uint16_t target_id,
 
 static void bnxt_accumulate_ctr(uint64_t hw, uint64_t *sw, uint64_t mask)
 {
-	uint64_t sw_tmp, prev, delta;
-
 	/* One of the HW stat values that make up this counter was zero as
 	 * returned by HW in this iteration, so use the previous
 	 * iteration's counter value
@@ -5398,39 +5396,59 @@ static void bnxt_accumulate_ctr(uint64_t hw, uint64_t *sw, uint64_t mask)
 		*sw = hw;
 		return;
 	}
-	prev = *sw & mask;
+	uint64_t prev = *sw & mask;
 	hw &= mask;
-	/*
-	 * Check if the absolute hw value is a single bit (power of 2)
-	 * and that we are able to end on a power of 2 for precise traffic
-	 * flows.
-	 */
-	if ((hw & (hw - 1)) == 0 && hw > (1ULL << 14)) {
-		delta = (hw - prev) & mask;
-		if (delta > (1ULL << 14))
-			return;
-	}
-	sw_tmp = (*sw & ~mask) | hw;
-	/* Under high frequency stats polling, the driver can sometimes report
-	 * stats that are too high then report the correct stats. Print a debug
-	 * message if this is the case and otherwise assume that it is a
-	 * rollover.
-	 */
+
+	/* handle a 48-bit counter rollover. */
 	if (hw < prev) {
 		if ((prev - hw) > (mask >> 1)) {
-			sw_tmp += mask + 1;
-		} else {
-			PMD_DRV_LOG_LINE(DEBUG,
-					 "stat backward step suppressed: "
-					 "prev=%llu hw=%llu drop=%llu mask=%llu",
-					 (unsigned long long)prev,
-					 (unsigned long long)hw,
-					 (unsigned long long)(prev - hw),
-					 (unsigned long long)mask);
-			return;
+			*sw = ((*sw & ~mask) | hw) + mask + 1; /* rollover */
+		}
+		/* else: small backward step - keep prev */
+		return;
+	}
+	*sw = (*sw & ~mask) | hw;
+}
+
+static uint64_t bnxt_pick_stat(uint64_t r1, uint64_t r2, uint64_t prev, uint64_t mask)
+{
+	uint64_t best = 0;
+	bool     have = false;
+
+	if (mask == 0 || mask == UINT64_MAX) {
+		return r2;
+	}
+
+	uint64_t a = r1 & mask;
+	uint64_t b = r2 & mask;
+	prev &= mask;
+
+	/* Reads agree -> no glitch, use the later (larger) read. */
+	if (a == b)
+		return b;
+
+	/* Among the reads >= prev, take the one closest to prev. */
+	if (a >= prev) {
+		best = a;
+		have = true;
+	}
+	if (b >= prev && (!have || (b - prev) < (best - prev))) {
+		best = b;
+		have = true;
+	}
+	if (have) {
+		uint64_t v = a > b ? a - b : b - a;
+		if (v > (1ULL << 28)) {
+			PMD_DRV_LOG_LINE(NOTICE, "STATS xcheck: r1=0x%" PRIx64 " r2=0x%" PRIx64 " prev=0x%" PRIx64 " -> 0x%" PRIx64, a, b, prev, best);
 		}
+		return best;
 	}
-	*sw = sw_tmp;
+
+	/* Both reads below prev: possible 48-bit rollover or both glitched
+	 * low. Warn and hand the later read to bnxt_accumulate_ctr to resolve.
+	 */
+	PMD_DRV_LOG_LINE(NOTICE, "STATS xcheck both<prev: r1=0x%" PRIx64 " r2=0x%" PRIx64 " prev=0x%" PRIx64, a, b, prev);
+	return b;
 }
 
 int bnxt_hwrm_ring_stats_masks(struct bnxt *bp,
@@ -5507,7 +5525,8 @@ int bnxt_hwrm_ring_stats(struct bnxt *bp, struct bnxt_cp_ring_info *cpr, int idx
 	struct bnxt_ring_stats *prev_stats = &bp->prev_rx_ring_stats[idx];
 	struct hwrm_stat_ctx_query_input req = {.req_type = 0};
 	struct hwrm_stat_ctx_query_output *resp = bp->hwrm_cmd_resp_addr;
-	uint64_t *prev_stats_u64, *hw_stats, *masks, *ring_stats_u64, i;
+	uint64_t hw1[BNXT_RING_STATS_CNT], hw2[BNXT_RING_STATS_CNT];
+	uint64_t *prev_stats_u64, *masks, *ring_stats_u64, i;
 	int rc;
 
 	if (!rx)
@@ -5521,30 +5540,41 @@ int bnxt_hwrm_ring_stats(struct bnxt *bp, struct bnxt_cp_ring_info *cpr, int idx
 
 		return 0;
 	}
-	HWRM_PREP(&req, HWRM_STAT_CTX_QUERY, BNXT_USE_CHIMP_MB);
 
+	/* First read. */
+	HWRM_PREP(&req, HWRM_STAT_CTX_QUERY, BNXT_USE_CHIMP_MB);
 	req.stat_ctx_id = rte_cpu_to_le_32(cpr->hw_stats_ctx_id);
-
 	rc = bnxt_hwrm_send_message(bp, &req, sizeof(req), BNXT_USE_CHIMP_MB);
+	HWRM_CHECK_RESULT();
+	for (i = 0; i < BNXT_RING_STATS_CNT; i++)
+		hw1[i] = rte_le_to_cpu_64(((uint64_t *)&resp->tx_ucast_pkts)[i]);
+	HWRM_UNLOCK();
 
+	/* Second, back-to-back read for the glitch cross-check. */
+	HWRM_PREP(&req, HWRM_STAT_CTX_QUERY, BNXT_USE_CHIMP_MB);
+	req.stat_ctx_id = rte_cpu_to_le_32(cpr->hw_stats_ctx_id);
+	rc = bnxt_hwrm_send_message(bp, &req, sizeof(req), BNXT_USE_CHIMP_MB);
 	HWRM_CHECK_RESULT();
+	for (i = 0; i < BNXT_RING_STATS_CNT; i++)
+		hw2[i] = rte_le_to_cpu_64(((uint64_t *)&resp->tx_ucast_pkts)[i]);
+	HWRM_UNLOCK();
 
 	masks = cpr->ring_stats_mask;
 	prev_stats_u64 = (uint64_t *)prev_stats;
-	hw_stats = (uint64_t *)&resp->tx_ucast_pkts;
 	ring_stats_u64 = (uint64_t *)ring_stats;
 
 	/* RX stats are >= 8 and TX are < 8 */
 	for (i = (rx) ? 8 : 0; i < BNXT_RING_STATS_CNT; i++) {
 		if (!rx && i >= 8)
 			continue;
-		bnxt_accumulate_ctr(rte_le_to_cpu_64(hw_stats[i]), &prev_stats_u64[i],
-				    masks[i]);
+
+		uint64_t hw = bnxt_pick_stat(hw1[i], hw2[i],
+					     prev_stats_u64[i], masks[i]);
+
+		bnxt_accumulate_ctr(hw, &prev_stats_u64[i], masks[i]);
 		ring_stats_u64[i] = prev_stats_u64[i];
 	}
 
-	HWRM_UNLOCK();
-
 	return rc;
 }
 
@@ -5587,7 +5617,8 @@ int bnxt_hwrm_ring_stats_ext(struct bnxt *bp, struct bnxt_cp_ring_info *cpr,
 	struct bnxt_ring_stats_ext *prev_stats = &bp->prev_rx_ring_stats_ext[idx];
 	struct hwrm_stat_ext_ctx_query_input req = {.req_type = 0};
 	struct hwrm_stat_ext_ctx_query_output *resp = bp->hwrm_cmd_resp_addr;
-	uint64_t *prev_stats_u64, *hw_stats, *masks, *ring_stats_u64, i;
+	uint64_t hw1[BNXT_RING_STATS_EXT_CNT], hw2[BNXT_RING_STATS_EXT_CNT];
+	uint64_t *prev_stats_u64, *masks, *ring_stats_u64, i;
 	int rc;
 
 	if (!rx)
@@ -5601,29 +5632,41 @@ int bnxt_hwrm_ring_stats_ext(struct bnxt *bp, struct bnxt_cp_ring_info *cpr,
 
 		return 0;
 	}
-	HWRM_PREP(&req, HWRM_STAT_EXT_CTX_QUERY, BNXT_USE_CHIMP_MB);
 
+	/* First read. */
+	HWRM_PREP(&req, HWRM_STAT_EXT_CTX_QUERY, BNXT_USE_CHIMP_MB);
 	req.stat_ctx_id = rte_cpu_to_le_32(cpr->hw_stats_ctx_id);
 	rc = bnxt_hwrm_send_message(bp, &req, sizeof(req), BNXT_USE_CHIMP_MB);
+	HWRM_CHECK_RESULT();
+	for (i = 0; i < BNXT_RING_STATS_EXT_CNT; i++)
+		hw1[i] = rte_le_to_cpu_64(((uint64_t *)&resp->rx_ucast_pkts)[i]);
+	HWRM_UNLOCK();
 
+	/* Second, back-to-back read for the glitch cross-check. */
+	HWRM_PREP(&req, HWRM_STAT_EXT_CTX_QUERY, BNXT_USE_CHIMP_MB);
+	req.stat_ctx_id = rte_cpu_to_le_32(cpr->hw_stats_ctx_id);
+	rc = bnxt_hwrm_send_message(bp, &req, sizeof(req), BNXT_USE_CHIMP_MB);
 	HWRM_CHECK_RESULT();
+	for (i = 0; i < BNXT_RING_STATS_EXT_CNT; i++)
+		hw2[i] = rte_le_to_cpu_64(((uint64_t *)&resp->rx_ucast_pkts)[i]);
+	HWRM_UNLOCK();
 
 	masks = cpr->ring_stats_ext_mask;
 	prev_stats_u64 = (uint64_t *)prev_stats;
-	hw_stats = (uint64_t *)&resp->rx_ucast_pkts;
 	ring_stats_u64 = (uint64_t *)ring_stats;
 
 	/* RX stats are < 8 and >= 16 and TX are >= 8 and < 16*/
 	for (i = (rx) ? 0 : 8; i < BNXT_RING_STATS_EXT_CNT; i++) {
 		if ((rx && (i >= 8 && i < 16)) || (!rx && i >= 16))
 			continue;
-		bnxt_accumulate_ctr(rte_le_to_cpu_64(hw_stats[i]), &prev_stats_u64[i],
-				    masks[i]);
+
+		uint64_t hw = bnxt_pick_stat(hw1[i], hw2[i],
+					     prev_stats_u64[i], masks[i]);
+
+		bnxt_accumulate_ctr(hw, &prev_stats_u64[i], masks[i]);
 		ring_stats_u64[i] = prev_stats_u64[i];
 	}
 
-	HWRM_UNLOCK();
-
 	return rc;
 }
 
-- 
