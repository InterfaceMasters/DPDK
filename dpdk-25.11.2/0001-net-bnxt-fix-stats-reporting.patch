+static uint64_t bnxt_pick_stat(uint64_t a, uint64_t b, uint64_t c, uint64_t prev)
+{
+	uint64_t med  = RTE_MAX(RTE_MIN(a, b), RTE_MIN(RTE_MAX(a, b), c));
+	uint64_t smin = RTE_MIN(RTE_MIN(a, b), c);
+	uint64_t smax = RTE_MAX(RTE_MAX(a, b), c);
+
+	if (smax - smin > (1ULL << 28))
+		PMD_DRV_LOG_LINE(NOTICE,
+			"STATS xcheck: r1=0x%llx r2=0x%llx r3=0x%llx prev=0x%llx -> 0x%llx",
+			(unsigned long long)a, (unsigned long long)b,
+			(unsigned long long)c, (unsigned long long)prev,
+			(unsigned long long)med);
+	return med;
+}
+
+static void bnxt_median_apply(uint64_t *r0, uint64_t *r1, uint64_t *r2,
+			      uint64_t *ring, uint64_t *prev,
+			      uint64_t start, uint64_t end)
+{
+	uint64_t i;
+
+	for (i = start; i < end; i++) {
+		ring[i] = bnxt_pick_stat(r0[i], r1[i], r2[i], prev[i]);
+		bnxt_update_prev_stat(&ring[i], &prev[i]);
+	}
+}
