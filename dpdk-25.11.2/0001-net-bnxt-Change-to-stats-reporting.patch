-static void bnxt_update_prev_stat(uint64_t *cntr, uint64_t *prev_cntr)
+static void bnxt_accumulate_ctr(uint64_t hw, uint64_t *sw, uint64_t mask)
 {
+	uint64_t sw_tmp, prev, delta;
+
 	/* One of the HW stat values that make up this counter was zero as
 	 * returned by HW in this iteration, so use the previous
 	 * iteration's counter value
 	 */
-	if (!cntr || !prev_cntr)
+	if (!hw)
 		return;
-	if (*prev_cntr && *cntr == 0)
-		*cntr = *prev_cntr;
-	else
-		*prev_cntr = *cntr;
+
+	if (mask == 0 || mask == UINT64_MAX) {
+		*sw = hw;
+		return;
+	}
+	prev = *sw & mask;
+	hw &= mask;
+	/*
+	 * Check if the absolute hw value is a single bit (power of 2)
+	 * and that we are able to end on a power of 2 for precise traffic
+	 * flows.
+	 */
+	if ((hw & (hw - 1)) == 0 && hw > (1ULL << 14)) {
+		delta = (hw - prev) & mask;
+		if (delta > (1ULL << 14))
+			return;
+	}
+	sw_tmp = (*sw & ~mask) | hw;
+	/* Under high frequency stats polling, the driver can sometimes report
+	 * stats that are too high then report the correct stats. Print a debug
+	 * message if this is the case and otherwise assume that it is a
+	 * rollover.
+	 */
+	if (hw < prev) {
+		if ((prev - hw) > (mask >> 1)) {
+			sw_tmp += mask + 1;
+		} else {
+			PMD_DRV_LOG_LINE(DEBUG,
+					 "stat backward step suppressed: "
+					 "prev=%llu hw=%llu drop=%llu mask=%llu",
+					 (unsigned long long)prev,
+					 (unsigned long long)hw,
+					 (unsigned long long)(prev - hw),
+					 (unsigned long long)mask);
+			return;
+		}
+	}
+	*sw = sw_tmp;
+}
