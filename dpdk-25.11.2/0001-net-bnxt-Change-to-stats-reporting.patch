+uint64_t bnxt_default_stat_mask(struct bnxt *bp)
+{
+	if (BNXT_CHIP_P5(bp) || BNXT_CHIP_P7(bp))
+		return (1ULL << 48) - 1;
+
+	return UINT64_MAX;
+}
+
+void bnxt_fill_stat_masks(uint64_t *masks, unsigned int cnt,
+			  const uint64_t *first, uint64_t def, bool query_ok)
+{
+	unsigned int i;
+
+	for (i = 0; i < cnt; i++)
+		masks[i] = query_ok ? rte_le_to_cpu_64(first[i]) : def;
+}
+
+void bnxt_clear_ring_stats_masks(struct bnxt *bp)
+{
+	uint64_t def = bnxt_default_stat_mask(bp);
+	uint16_t queue_idx;
+
+	for (queue_idx = 0; bp->rx_queues && queue_idx < bp->rx_cp_nr_rings; queue_idx++) {
+		struct bnxt_rx_queue *rxq = bp->rx_queues[queue_idx];
+
+		if (rxq == NULL || rxq->cp_ring == NULL)
+			continue;
+
+		bnxt_fill_stat_masks(rxq->cp_ring->ring_stats_mask,
+				     BNXT_RING_STATS_CNT,
+				     rxq->cp_ring->ring_stats_mask,
+				     def, false);
+		bnxt_fill_stat_masks(rxq->cp_ring->ring_stats_ext_mask,
+				     BNXT_RING_STATS_EXT_CNT,
+				     rxq->cp_ring->ring_stats_ext_mask,
+				     def, false);
+	}
+
+	for (queue_idx = 0; bp->tx_queues && queue_idx < bp->tx_cp_nr_rings; queue_idx++) {
+		struct bnxt_tx_queue *txq = bp->tx_queues[queue_idx];
+
+		if (txq == NULL || txq->cp_ring == NULL)
+			continue;
+		bnxt_fill_stat_masks(txq->cp_ring->ring_stats_mask,
+				     BNXT_RING_STATS_CNT,
+				     txq->cp_ring->ring_stats_mask,
+				     def, false);
+		bnxt_fill_stat_masks(txq->cp_ring->ring_stats_ext_mask,
+				     BNXT_RING_STATS_EXT_CNT,
+				     txq->cp_ring->ring_stats_ext_mask,
+				     def, false);
+	}
+}
